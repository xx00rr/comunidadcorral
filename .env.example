# Copiar a .env y completar con valores reales
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
DEBUG=False
ALLOWED_HOSTS=tu-dominio.railway.app,tu-dominio.vercel.app

# PostgreSQL (Railway lo provee automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Para CSRF
CSRF_TRUSTED_ORIGINS=https://tu-dominio.railway.app,https://tu-dominio.vercel.app
